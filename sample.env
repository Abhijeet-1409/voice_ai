# ─────────────────────────────────────────────────────────────────────────────
# Intelics Voice AI Agent — Sample Environment File
# Copy this file to .env and fill in your actual values
# cp sample.env .env
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM — Gemini 2.5 Flash ───────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_your_gemini_api_key_here

# ── Email — Gmail SMTP ────────────────────────────────────────────────────────
# Your Gmail address
GMAIL_ADDRESS=yourname@gmail.com

# App password (NOT your regular Gmail password)
# How to get: myaccount.google.com → Security → 2-Step Verification → App Passwords
# Looks like: abcd efgh ijkl mnop
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Sales team email — call summaries are sent here
NOTIFICATION_EMAIL=sales@yourcompany.com

# ── Redis ─────────────────────────────────────────────────────────────────────
# When running via docker-compose, use service name "redis" not "localhost"
REDIS_HOST=redis
REDIS_PORT=6379

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# When running via docker-compose, use service name "postgres" not "localhost"
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:yourpassword@postgres:5432/voice_ai

# PostgreSQL password (used by docker-compose to create the database)
POSTGRES_PASSWORD=yourpassword

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=8000
