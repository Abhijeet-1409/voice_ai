# ─────────────────────────────────────────────────────────────────────────────
# Intelics Voice AI Agent — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# ── Virtual Environment ───────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep docker-compose.yml and Dockerfile in git
# Ignore generated volumes and local overrides
docker-compose.override.yml

# ── Audio test files ──────────────────────────────────────────────────────────
*.wav
*.mp3
*.webm
*.ogg
*.flac

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Excel Files ────────────────────────────────────────────────────────────────
*.xlsx
*.xls